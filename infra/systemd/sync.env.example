# Copy outside the repository to /etc/pj-general/sync.env. Never commit real values.
# The checked-in timer stays dry-run-only until a user-approved manual commit.
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=gemma4:latest
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT_MS=60000

# Slack memo-ideas: channels:history only; bot is a member of this channel.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=C0BG4TCPAUD
SLACK_OWNER_USER_ID=
SLACK_INITIAL_OLDEST_TS=

# Misskey: access token is optional when the selected visibility does not need it.
MISSKEY_BASE_URL=
MISSKEY_ACCESS_TOKEN=
MISSKEY_OWNER_USER_ID=
