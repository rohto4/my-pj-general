# Copy outside the repository to /etc/pj-general/backup.env and restrict to 0600.
PJ_DB_PATH=/home/unibell4/.local/share/pj-general/p0.sqlite
VIKUNJA_DB_PATH=/srv/pj-general/data/vikunja/db/vikunja.db
VIKUNJA_FILES_PATH=/srv/pj-general/data/vikunja/files
VIKUNJA_SECRET_PATH=/srv/pj-general/secrets/vikunja.env
BACKUP_ROOT=/home/unibell4/.local/share/pj-general/backups
# Container-visible copies consumed by Hub GET /api/observability.
P0_BACKUP_DIR=/home/unibell4/.local/share/pj-general/backups/hub
# Set this only to a mounted NAS / external disk path.
MIRROR_ROOT=
KEEP_GENERATIONS=7
